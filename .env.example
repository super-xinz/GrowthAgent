APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
SECRET_KEY=replace_with_a_random_32_byte_secret
ENCRYPTION_KEY=replace_with_a_different_random_32_byte_secret
POSTGRES_PASSWORD=replace_with_a_random_database_password
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/reddit_growth
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# 默认使用 Mock，可启动后在“设置 → 模型服务”中安全填写 API Key。
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_STRONG_MODEL=
LLM_TIMEOUT_SECONDS=150
LLM_ENABLE_THINKING=false
GLOBAL_KILL_SWITCH=false
XIAOHONGSHU_MCP_URL=http://xiaohongshu-mcp:18060
XIAOHONGSHU_SEARCH_TIMEOUT_SECONDS=75
XIAOHONGSHU_AUTO_SCORE_THRESHOLD=0.75
XIAOHONGSHU_AUTO_RISK_THRESHOLD=0.35
XIAOHONGSHU_SEARCH_INTERVAL_HOURS=3
XIAOHONGSHU_MIN_PUBLISH_INTERVAL_HOURS=4
XIAOHONGSHU_KEYWORDS_PER_RUN=3
XIAOHONGSHU_DETAILS_PER_KEYWORD=2
